generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Client {
  id         String   @id @default(uuid())
  name       String
  email      String   @unique
  cnpj       String?
  clientType String   // "new" or "old"
  password   String   // Senha segura para o cliente acessar o portal
  projects   Project[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Project {
  id                 String   @id // Usado para PROJ-XXXX
  name               String
  phase              String
  financial          String
  value              Float
  domainHostingValue Float    @default(0)
  
  // Features do portal
  seo                Boolean  @default(false)
  analytics          Boolean  @default(false)
  support            Boolean  @default(false)
  ads                Boolean  @default(false)
  
  internalNotes      String?
  repoUrl            String?  // URL do repositório GitHub
  productionUrl      String?  // URL do site em produção
  
  clientId           String
  client             Client   @relation(fields: [clientId], references: [id])
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  invoices           Invoice[]
  files              ProjectFile[]
}

model Invoice {
  id          String   @id @default(uuid())
  description String
  amount      Float
  status      String   @default("pending") // pending, paid, canceled, overdue
  type        String   @default("service")  // service, nf, contract
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  dueDate     DateTime?
  paidAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Document {
  id          String   @id @default(uuid())
  title       String
  type        String
  clientName  String
  date        String
  url         String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ProjectFile {
  id           String   @id @default(uuid())
  originalName String
  fileName     String   // stored filename on disk
  mimeType     String
  size         Int      // in bytes
  path         String   // relative path to the upload
  category     String   @default("other") // brand, copy, media, access, contract, nf, delivery, other
  uploadedBy   String   @default("client") // client | admin
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id])
  createdAt    DateTime @default(now())
}

