# ─── Database (Prisma Postgres Cloud) ────────────────────────────────────────
# Pooled connection — used by the app server at runtime
DATABASE_URL="postgres://USER:PASSWORD@pooled.db.prisma.io:5432/postgres?sslmode=require"
# Direct connection — used only by Prisma CLI (migrations, prisma studio)
DIRECT_URL="postgres://USER:PASSWORD@db.prisma.io:5432/postgres?sslmode=require"

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET="your-strong-random-secret-here"
ADMIN_PASSWORD="your-admin-password-here"

# ─── Mercado Pago ─────────────────────────────────────────────────────────────
VITE_MP_PUBLIC_KEY="TEST-xxxxxxxxxxxxxxxxxxxxxxxx"
MP_ACCESS_TOKEN="TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
