# ============================================
# REQUIRED — App will NOT start without these
# ============================================

# PostgreSQL connection (pooled)
DATABASE_URL=

# PostgreSQL direct connection (for migrations only)
DIRECT_URL=

# JWT signing secret — minimum 32 characters, keep secret
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# bcrypt hash of the admin password
# Generate: npm run generate:admin-hash
ADMIN_PASSWORD_HASH=

# ============================================
# OPTIONAL
# ============================================

NODE_ENV=production

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=https://thomaseduardo.online

# Port for the Express server
PORT=3001

# Required only for seeding (blocks the seed route unless this matches)
SEED_SECRET=

# Mercado Pago (if using payments)
VITE_MP_PUBLIC_KEY=
MP_ACCESS_TOKEN=
