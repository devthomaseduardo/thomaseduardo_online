generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// CLIENTES
// ==========================================

model Client {
  id             String    @id @default(uuid())
  name           String
  email          String    @unique
  cnpj           String?
  clientType     String    @default("new")
  password       String
  phone          String?
  obs            String?
  portalKey      String?   @unique
  portalActive   Boolean   @default(true)
  portalExpires  DateTime?
  ltv            Float?    @default(0)
  score          Int?      @default(0)
  lastLogin      DateTime?
  projects       Project[]
  proposals      Proposal[]
  messages       Message[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("Client")
}

// ==========================================
// PROJETOS
// ==========================================

model Project {
  id                 String          @id @default(uuid())
  name               String
  phase              String          @default("Briefing")
  financial          String          @default("pending")
  value              Float           @default(0)
  domainHostingValue Float           @default(0)
  status             String          @default("briefing")
  progresso          Int             @default(0)
  tipo               String          @default("website")
  descricao          String?
  proximaAcao        String?
  dataEntregaPrevista DateTime?

  seo                Boolean  @default(false)
  analytics          Boolean  @default(false)
  support            Boolean  @default(false)
  ads                Boolean  @default(false)

  internalNotes      String?
  repoUrl            String?
  productionUrl      String?

  clientId           String
  client             Client   @relation(fields: [clientId], references: [id])

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  invoices           Invoice[]
  files              ProjectFile[]
  timeline           TimelineEvent[]
  tasks              Task[]
  contracts          Contract[]
  deploys            Deploy[]
  integrations       Integration[]
  proposals          Proposal[]
  messages           Message[]

  @@map("Project")
}

// ==========================================
// TAREFAS
// ==========================================

model Task {
  id             String    @id @default(uuid())
  titulo         String
  descricao      String?
  status         String    @default("pendente") // pendente, em_andamento, bloqueada, concluida
  prioridade     String    @default("media")    // baixa, media, alta, urgente
  responsavel    String?
  prazo          DateTime?
  visivelCliente Boolean   @default(false)
  ordem          Int       @default(0)

  projectId      String
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("Task")
}

// ==========================================
// TIMELINE
// ==========================================

model TimelineEvent {
  id             String    @id @default(uuid())
  titulo         String
  descricao      String?
  tipo           String    @default("admin") // sistema, admin, cliente, financeiro, contrato, upload, deploy, projeto
  visivelCliente Boolean   @default(false)
  criadoPor      String    @default("admin")

  projectId      String
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("TimelineEvent")
}

// ==========================================
// FINANCEIRO
// ==========================================

model Invoice {
  id               String    @id @default(uuid())
  description      String
  amount           Float
  status           String    @default("pending") // pending, paid, partial, canceled, overdue
  type             String    @default("service")
  valorPago        Float     @default(0)
  saldo            Float     @default(0)
  vencimento       DateTime?
  paidAt           DateTime?
  metodoPagamento  String?
  pixCopiaCola     String?
  mercadoPagoUrl   String?

  projectId        String
  project          Project   @relation(fields: [projectId], references: [id])

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  payments         Payment[]

  @@map("Invoice")
}

model Payment {
  id        String    @id @default(uuid())
  invoiceId String
  invoice   Invoice   @relation(fields: [invoiceId], references: [id])
  valor     Float
  metodo    String
  status    String    @default("pago")
  pagoEm   DateTime  @default(now())
  createdAt DateTime  @default(now())

  @@map("Payment")
}

// ==========================================
// CONTRATOS
// ==========================================

model Contract {
  id             String    @id @default(uuid())
  titulo         String
  status         String    @default("rascunho") // rascunho, enviado, assinado, cancelado
  versao         String    @default("1.0")
  fileUrl        String?
  visivelCliente Boolean   @default(false)
  enviadoEm      DateTime?
  assinadoEm     DateTime?

  projectId      String
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("Contract")
}

// ==========================================
// DEPLOYS
// ==========================================

model Deploy {
  id             String    @id @default(uuid())
  ambiente       String    @default("production") // production, staging, preview
  url            String?
  provider       String    @default("vercel")
  status         String    @default("pending") // pending, building, success, failed
  branch         String    @default("main")
  commitHash     String?
  logs           String?
  visivelCliente Boolean   @default(false)
  deployedAt     DateTime?

  projectId      String
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("Deploy")
}

// ==========================================
// ARQUIVOS
// ==========================================

model ProjectFile {
  id             String    @id @default(uuid())
  originalName   String
  fileName       String
  mimeType       String
  size           Int
  path           String
  category       String    @default("other")
  uploadedBy     String    @default("client")
  status         String    @default("pendente") // pendente, aprovado, rejeitado
  visivelCliente Boolean   @default(true)

  projectId      String
  project        Project   @relation(fields: [projectId], references: [id])

  createdAt      DateTime  @default(now())

  @@map("ProjectFile")
}

// ==========================================
// ANALYTICS / INTEGRAÇÕES
// ==========================================

model Integration {
  id             String    @id @default(uuid())
  tipo           String    // google_analytics, gtm, meta_pixel, google_ads, search_console
  identificador  String?
  dashboardUrl   String?
  status         String    @default("ativo")
  visivelCliente Boolean   @default(false)
  metricas       String?   // JSON com métricas manuais

  projectId      String
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("Integration")
}

// ==========================================
// PROPOSTAS COMERCIAIS

model Proposal {
  id            String    @id @default(uuid())
  title         String
  description   String?
  status        String    @default("draft") // draft, sent, approved, rejected
  stage         String    @default("draft")
  amount        Float     @default(0)
  version       Int       @default(1)
  approvalLink  String?
  acceptedAt    DateTime?

  clientId      String?
  client        Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projectId     String?
  project       Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("Proposal")
}

// ==========================================
// LEADS E CRM

model Lead {
  id             String    @id @default(uuid())
  name           String
  email          String?
  phone          String?
  source         String?   @default("site")
  status         String    @default("new") // new, qualified, meeting, proposal, won, lost
  owner          String?
  notes          String?
  nextActionAt   DateTime?
  converted      Boolean   @default(false)
  convertedAt    DateTime?
  convertedToId  String?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("Lead")
}

// ==========================================
// MENSAGENS

model Message {
  id           String    @id @default(uuid())
  projectId    String?
  clientId     String?
  senderType   String    @default("internal") // internal, client, system
  senderName   String?
  content      String
  read         Boolean   @default(false)

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  project      Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  client       Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("Message")
}

// ==========================================
// EQUIPE / USUÁRIOS INTERNOS

model TeamMember {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  role         String   @default("editor")
  permissions  String?  // JSON string with permission flags
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now())

  @@map("TeamMember")
}

// ==========================================
// DOCUMENTOS LEGADOS (manter compatibilidade)
// ==========================================

model Document {
  id          String   @id @default(uuid())
  title       String
  type        String
  clientName  String
  date        String
  url         String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("Document")
}

// ==========================================
// SECURITY / AUDIT
// ==========================================

model SecurityLog {
  id        String   @id @default(uuid())
  action    String
  actorType String   @default("system")
  actorId   String?
  ip        String?
  userAgent String?
  metadata  String?  // JSON - never stores passwords or tokens
  createdAt DateTime @default(now())

  @@map("SecurityLog")
}
